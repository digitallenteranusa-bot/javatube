# GamanTube Environment Variables

# JWT Secret - WAJIB diganti untuk production!
JWT_SECRET=ganti-dengan-secret-key-yang-kuat-dan-random

# Port server (default: 3000)
PORT=3000

# Host (default: 0.0.0.0)
HOST=0.0.0.0

# App URL (untuk link di email)
APP_URL=http://localhost:3000

# SMTP Configuration (kosongkan untuk mode development - log ke console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gamantube.local
